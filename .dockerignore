# Keep the Docker build context lean — only what the agent actually needs.
.git/
.github/
.gitignore
.gitattributes
.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local-only / heavy / unrelated subprojects
data/
docs/
data-gen/*
!data-gen/taxonomy.yaml
frontend/
infra/
pipelines/

# Local envs / IDE
.env
.env.*
!.env.example
.vscode/
.idea/
.DS_Store

# Markdown & other docs
ARCHITECTURE.md
PROJECT_OVERVIEW.md
README.md
